entity:SetCallback("OnDespawning", function()
	if chaseConnection then
		chaseConnection:Disconnect()
		chaseConnection = nil
	end
	if destroyTimer then
		task.cancel(destroyTimer)
		destroyTimer = nil
	end

	-- Force clean and turn off running audio elements upon Despawn sequence trigger
	for sound, _ in pairs(activeSounds) do
		if sound then
			pcall(function()
				if sound.Playing then sound:Stop() end
				sound:Destroy()
			end)
		end
	end
	activeSounds = {}

	-- Destroy static overlay instances immediately upon despawn
	if spawnedOverlayGui then
		spawnedOverlayGui:Destroy()
		spawnedOverlayGui = nil
	end
	local residualStatic = LocalPlayer.PlayerGui:FindFirstChild("StaticGUI")
	if residualStatic then residualStatic:Destroy() end

	TweenService:Create(colorCorrection, TweenInfo.new(2.5), {Contrast = originalContrast}):Play()
	TweenService:Create(colorCorrection, TweenInfo.new(5), {TintColor = originalTintColor}):Play()

	if entityModel then
		for _, part in ipairs(entityModel:GetDescendants()) do
			if part:IsA("BasePart") then
				part.Anchored = false
			end
		end
	end
end)

