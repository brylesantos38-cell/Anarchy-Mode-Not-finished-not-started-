entity:SetCallback("OnSpawned", function()
	print("Thực thể đã xuất hiện (spawn)")
	
	local Lord = Instance.new("Sound")
	Lord.SoundId = "rbxassetid://4636847934"
	Lord.Parent = workspace
	Lord.Volume = 3
	Lord.PlaybackSpeed = 1
	Lord:Play()
	activeSounds[Lord] = true

	entityModel = entity.Model
	entityModel.Parent = workspace

	if entityModel then
		entityPart = entityModel:FindFirstChild("RushNew")
		if not entityPart then
			entityPart = entityModel.PrimaryPart or entityModel:FindFirstChildOfClass("BasePart")
			if not entityPart then
				return
			end
		end
		entityModel.PrimaryPart = entityPart
		
		if entityPart:IsA("BasePart") then
			entityPart.CanCollide = false
		end
	end

	coroutine.wrap(function()
		for i, v in ipairs(entityModel:GetDescendants()) do
			if v.Name == "RushNew" then
				pcall(function()
					if v:FindFirstChild("Breathing") then v.Breathing:Destroy() end
				end)
				pcall(function()
					if v:FindFirstChild("Footsteps") then v.Footsteps:Destroy() end
				end)
			end
		end
	end)()

	originalTintColor = colorCorrection.TintColor
	originalContrast = colorCorrection.Contrast

	colorCorrection.TintColor = Color3.fromRGB(255, 255, 255)
	colorCorrection.Contrast = 0.1
	TweenService:Create(colorCorrection, TweenInfo.new(2.5), {Contrast = 0}):Play()
	TweenService:Create(colorCorrection, TweenInfo.new(5), {TintColor = Color3.fromRGB(255, 255, 255)}):Play()

	MoveActive = true

	if chaseConnection then chaseConnection:Disconnect() end
	chaseConnection = RunService.Heartbeat:Connect(function(dt)
		if not MoveActive or not entityModel or not entityModel.PrimaryPart or not HumanoidRootPart or not HumanoidRootPart.Parent then return end

		local pos = entityModel.PrimaryPart.Position
		local target = HumanoidRootPart.Position
		local distance = (target - pos).Magnitude

		if distance <= activationRange then 
			local dir = (target - pos).Unit
			local moveVec = dir * customSpeed * dt
			local newCFrame = CFrame.new(pos + moveVec, target)
			entityModel:SetPrimaryPartCFrame(newCFrame)
		end
	end)

	task.spawn(function()
		MainGame.caption("Guiding light: RUN!, RIGHT NOW IM NOT JOKING", true)
		task.wait(3.5)
		
		MainGame.caption("Deer God: Let me see you......you can't run you can't hide it will follow you...", true)
		task.wait(4.5)
		
		local screamSound = Instance.new("Sound")
		screamSound.SoundId = "rbxassetid://139310882854462"
		screamSound.Volume = 3
		screamSound.Parent = workspace
		screamSound:Play()
		activeSounds[screamSound] = true
		Debris:AddItem(screamSound, 6)
		
		MainGame.caption("Human: A̷͉̬͊͌͆̅͊̋́̕H̵̡̧̫͓̤̞̜͇̙̱͍̠͖͇͌͑͆͋̆͌̓̈̚͝Ḩ̸̡͕̺̲̬͓͊̒͗̾̂̉͐̎̈́͗͠͝H̵̭̦̩͕̬̩͙̟͕̹̃͆̈́H̸͔͈̬̔̂͌͝H̸̨̪̙̩͔̾̈́͊̿̊̈̓͠Ḧ̶̼̯͕̰̺̱̞͕̲͈̈́͘ͅH̵͕̤͇̠̠͈́̓̕̚͘͜͠͝", true)
		task.wait(4)
		
		local backgroundSnd = Instance.new("Sound")
		backgroundSnd.SoundId = "rbxassetid://124606578932734"
		backgroundSnd.Volume = 2.5
		backgroundSnd.Parent = workspace
		backgroundSnd:Play()
		activeSounds[backgroundSnd] = true
		Debris:AddItem(backgroundSnd, 8)
		
		MainGame.caption("Guiding light: Run as fast as you can, it's deer god yes his different just run", true)
	end)

	-- Updated chase lifetime duration threshold to fall exactly between 20 and 21 seconds
	if destroyTimer then task.cancel(destroyTimer) end
	destroyTimer = task.delay(math.random(200, 210) / 10, function()
		MoveActive = true 
		task.wait(0.1) 
		if entityModel and entityModel.PrimaryPart then
			entityModel:SetPrimaryPartCFrame(entityModel.PrimaryPart.CFrame * CFrame.new(0, -300, 0)) 
		end
		task.wait(0) 
		entity:Despawn() 
	end)

	local spawnedRushNew = entityModel:FindFirstChild("RushNew")
	if spawnedRushNew then
		spawnedRushNew.Touched:Connect(function(hit)
			local h = hit.Parent and hit.Parent:FindFirstChild("Humanoid")
			if h and hit:IsDescendantOf(Character) then
				h:TakeDamage(100)
				doJumpscareWithEffect()
				local stats = game:GetService("ReplicatedStorage").GameStats
				if stats:FindFirstChild("Player_"..LocalPlayer.Name) then
					stats["Player_"..LocalPlayer.Name].Total.DeathCause.Value = "Deer God"
				end
			end
		end)
		
		spawnedOverlayGui = Instance.new("ScreenGui")
		spawnedOverlayGui.Name = "JumpscareOverlay"
		spawnedOverlayGui.IgnoreGuiInset = true
		spawnedOverlayGui.DisplayOrder = 999999
		spawnedOverlayGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

		local imageLabel = Instance.new("ImageLabel")
		imageLabel.BackgroundTransparency = 1
		imageLabel.BorderSizePixel = 0
		imageLabel.Position = UDim2.new(0, 0, 0, 0)
		imageLabel.Size = UDim2.new(1, 0, 1, 0)
		imageLabel.ScaleType = Enum.ScaleType.Stretch
		imageLabel.ImageTransparency = 0.7
		imageLabel.Visible = true
		imageLabel.Parent = spawnedOverlayGui

		local jumpscareImage1 = "rbxassetid://134346506410955"		
		local jumpscareImage2 = "rbxassetid://7578853379"
		local jumpscareImage3 = "rbxassetid://103846711769666"
		local jumpscareImage4 = "rbxassetid://78199392475572"

		local flashDuration = 35
		local start = tick()

		task.spawn(function()
			while tick() - start < flashDuration do
				if not imageLabel or not imageLabel.Parent then break end
				imageLabel.Image = jumpscareImage1
				task.wait()
				imageLabel.Image = jumpscareImage2
				task.wait()
				imageLabel.Image = jumpscareImage3
				task.wait()
				imageLabel.Image = jumpscareImage4
				task.wait()
			end
			if imageLabel and imageLabel.Parent then imageLabel:Destroy() end
		end)
	end
end)

