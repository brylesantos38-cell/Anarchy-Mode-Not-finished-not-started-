---====== Helper Functions ======---

local function GitAud(soundgit, filename)
    local FileName = filename .. ".mp3"
    
    if isfile(FileName) then
        return (getcustomasset or getsynasset)(FileName)
    end
    
    local success, result = pcall(function()
        return game:HttpGet(soundgit)
    end)
    
    if success and result then
        writefile(FileName, result)
        return (getcustomasset or getsynasset)(FileName)
    else
        warn("Failed to download audio: " .. tostring(filename))
        return ""
    end
end

local function CustomGitSound(soundlink, vol, filename)
    local assetId = GitAud(soundlink, filename)
    if assetId ~= "" then
        local Sound = Instance.new("Sound")
        Sound.SoundId = assetId
        Sound.Parent = workspace
        Sound.Volume = vol or 3
        Sound:Play()
        game.Debris:AddItem(Sound, 10) 
    end
end

-- Red Warning Light System Manipulation
local function light(tim, color0, color1)
	local tweenservice = game:GetService("TweenService")
	local info = TweenInfo.new(tim, Enum.EasingStyle.Linear)
	for _, lightInstance in pairs(game.Workspace.CurrentRooms:GetDescendants()) do
		if lightInstance:IsA("Light") or lightInstance:IsA("SurfaceLight") or lightInstance:IsA("SpotLight") then
			local target = {Color = color1}
			local anim = tweenservice:Create(lightInstance, info, target)
			anim:Play()
		end
		if lightInstance:IsA("MeshPart") and lightInstance.Material == Enum.Material.Neon and lightInstance.Name ~= "Skybox" then
			local target1 = {Color = color0}
			local anim2 = tweenservice:Create(lightInstance, info, target1)
			anim2:Play()
		end
	end
end

